---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav';
import HeroSlideshow from '../../sections/HeroSlideshow';
import ServicesSection from '../../sections/ServicesSection.astro';
import ProcessSection from '../../sections/ProcessSection.astro';
import AboutSection from '../../sections/AboutSection.astro';
import ContactSection from '../../sections/ContactSection';
import SiteFooter from '../../sections/SiteFooter.astro';
import { getT } from '../../i18n/translations';

const lang = 'en';
const tr = getT(lang);
---

<BaseLayout
  lang={lang}
  title="vision2code | Webapps, AI & Automation"
  description="I build webapps, APIs, AI integrations and automation. From concept to running server, remote and worldwide."
  canonicalPath="/"
>
  <SiteNav lang={lang} client:load />
  <main>
    <HeroSlideshow lang={lang} client:load />
    <ServicesSection tr={tr} lang={lang} />
    <ProcessSection  tr={tr} lang={lang} />
    <AboutSection    tr={tr} lang={lang} />
    <ContactSection  lang={lang} client:idle />
  </main>
  <SiteFooter tr={tr} lang={lang} />
</BaseLayout>
