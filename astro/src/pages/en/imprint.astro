---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav';
import ImpressumPage from '../../sections/ImpressumPage';
import SiteFooter from '../../sections/SiteFooter.astro';
import { getT } from '../../i18n/translations';

const lang = 'en';
const tr = getT(lang);
const altLegalHref = '/impressum';
---

<BaseLayout
  lang={lang}
  title="Legal Notice · vision2code"
  description="Legal notice of vision2code pursuant to § 5 TMG."
  canonicalPath="/imprint"
  altPath="/impressum"
  isLegal={true}
>
  <SiteNav lang={lang} isLegal={true} altLegalHref={altLegalHref} selfPath="/en/imprint" client:load />
  <ImpressumPage section="impressum" lang={lang} />
  <SiteFooter tr={tr} lang={lang} isLegal={true} altLegalHref={altLegalHref} />
</BaseLayout>
