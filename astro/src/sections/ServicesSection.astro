---
import type { Translations, Lang } from '../i18n/translations';
import { anchors } from '../i18n/translations';

interface Props { tr: Translations; lang: Lang }
const { tr, lang } = Astro.props;

const services = [
  { n: '01', title: tr.svc_webapp,  body: tr.svc_webapp_desc,  tags: ['React', 'Next.js', 'TypeScript', 'Postgres'] },
  { n: '02', title: tr.svc_website, body: tr.svc_website_desc, tags: ['Astro', 'Shopify', 'Sanity', 'SEO'] },
  { n: '03', title: tr.svc_api,     body: tr.svc_api_desc,     tags: ['REST', 'GraphQL', 'Webhooks', 'OAuth'] },
  { n: '04', title: tr.svc_ai,      body: tr.svc_ai_desc,      tags: ['OpenAI', 'Claude', 'pgvector', 'Whisper'] },
  { n: '05', title: tr.svc_auto,    body: tr.svc_auto_desc,    tags: ['n8n', 'Python', 'Cron', 'Playwright'] },
  { n: '06', title: tr.svc_consult, body: tr.svc_consult_desc, tags: ['Audit', 'Roadmap', 'Sparring', 'Support'] },
];
---

<section id={anchors[lang].services} style="background: var(--paper); padding-bottom: clamp(80px,12vh,160px)">
  <div style="max-width: 1080px; margin: 0 auto; padding: clamp(72px,10vh,140px) var(--shell-pad) 48px">
    <div class="eyebrow">{tr.svc_title}</div>
    <h2 style="margin: 16px 0 0; font-size: clamp(40px,5.5vw,88px); font-weight: 600; letter-spacing: -0.03em; line-height: 0.96; text-wrap: balance">
      {tr.svc_headline}
    </h2>
    <p style="margin: 32px 0 0; max-width: 640px; font-size: clamp(17px,1.4vw,19px); line-height: 1.55; color: var(--ink-2)">
      {tr.svc_intro}
    </p>
  </div>

  <div class="services-grid" style="max-width: 1280px; margin: 0 auto; padding: 0 var(--shell-pad); display: grid; grid-template-columns: repeat(auto-fill,minmax(320px,1fr)); gap: 20px">
    {services.map((s) => (
      <article class="lift service-card" style="background: #fff; border: 1px solid var(--hairline); border-radius: 24px; padding: 32px 32px 28px; display: flex; flex-direction: column; min-height: 280px">
        <div style="display: flex; justify-content: space-between; align-items: flex-start">
          <span style="font-family: var(--font-mono); font-size: 12px; color: var(--mute)">{s.n}</span>
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><path d="M3 8 H13 M9 4 L13 8 L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
        </div>
        <h3 class="service-card-title" style="margin: 40px 0 12px; font-size: 26px; font-weight: 600; letter-spacing: -0.015em">{s.title}</h3>
        <p class="service-card-body" style="margin: 0; color: var(--ink-2); font-size: 15px; line-height: 1.55; flex: 1">{s.body}</p>
        <div class="service-card-tags" style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 24px">
          {s.tags.map(t => (
            <span style="font-family: var(--font-mono); font-size: 11px; color: var(--mute); padding: 5px 10px; border: 1px solid var(--hairline); border-radius: 999px; letter-spacing: 0.04em">{t}</span>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>
