---
import type { Translations } from '../i18n/translations';

interface Props {
  tr: Translations;
  lang: 'de' | 'en';
  isLegal?: boolean;
  altLegalHref?: string;
}
const { tr, lang, isLegal = false, altLegalHref } = Astro.props;

const altHref = isLegal && altLegalHref
  ? altLegalHref
  : (lang === 'de' ? '/en/' : '/');

const legalItems: [string, string][] = [
  [tr.footer_imprint, lang === 'en' ? '/en/imprint'        : '/impressum'],
  [tr.footer_privacy, lang === 'en' ? '/en/privacy-policy' : '/datenschutz'],
  [tr.footer_tos,     lang === 'en' ? '/en/terms'          : '/agb'],
];
---

<footer style="background: var(--night); color: #fff; padding: clamp(64px,8vh,96px) var(--shell-pad) 32px; font-family: var(--font-fellix)">
  <div style="max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit,minmax(220px,1fr)); gap: 48px; align-items: start">

    <!-- Brand col -->
    <div>
      <a href={lang === 'en' ? '/en/' : '/'} style="display: inline-flex; align-items: center; gap: 10px; color: #fff; text-decoration: none; font-weight: 600; font-size: 20px; letter-spacing: -0.01em">
        <svg width="28" height="28" viewBox="0 0 40 40" fill="none" aria-hidden="true">
          <path d="M5 8 L19 20 L5 32" stroke="currentColor" stroke-width="3.2" stroke-linejoin="miter" stroke-linecap="square"/>
          <path d="M22 32 L30 8" stroke="currentColor" stroke-width="3.2" stroke-linecap="square"/>
          <circle cx="33.5" cy="30" r="2.6" fill="currentColor"/>
        </svg>
        v2c
      </a>
      <p style="margin: 24px 0 24px; font-size: 14px; line-height: 1.6; color: rgba(255,255,255,0.72); max-width: 320px">{tr.footer_desc}</p>
      <a href="mailto:hallo@vision2co.de" class="u-link" style="color: #fff; font-size: 14px">hallo@vision2co.de</a>
    </div>

    <!-- Services col -->
    <div>
      <h4 style="margin: 0 0 18px; font-size: 14px; font-weight: 600; letter-spacing: 0.02em; text-transform: uppercase; color: rgba(255,255,255,0.8)">{tr.footer_services}</h4>
      <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 11px">
        {[tr.svc_webapp, tr.svc_website, tr.svc_api, tr.svc_ai, tr.svc_auto, tr.svc_consult].map(label => (
          <li><a href={lang === 'en' ? '/en/#leistungen' : '/#leistungen'} style="color: rgba(255,255,255,0.72); text-decoration: none; font-size: 14px">{label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Studio col -->
    <div>
      <h4 style="margin: 0 0 18px; font-size: 14px; font-weight: 600; letter-spacing: 0.02em; text-transform: uppercase; color: rgba(255,255,255,0.8)">{tr.footer_studio}</h4>
      <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 11px">
        {([
          [tr.nav_process, '#prozess'],
          [tr.nav_about,   '#ueber'],
          [tr.nav_contact, '#kontakt'],
        ] as [string,string][]).map(([label, href]) => (
          <li><a href={lang === 'en' ? `/en/${href}` : href} style="color: rgba(255,255,255,0.72); text-decoration: none; font-size: 14px">{label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Legal col -->
    <div>
      <h4 style="margin: 0 0 18px; font-size: 14px; font-weight: 600; letter-spacing: 0.02em; text-transform: uppercase; color: rgba(255,255,255,0.8)">{tr.footer_legal}</h4>
      <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 11px">
        {legalItems.map(([label, href]) => (
          <li><a href={href} style="color: rgba(255,255,255,0.72); text-decoration: none; font-size: 14px">{label}</a></li>
        ))}
      </ul>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="grid-footer-bottom" style="margin-top: clamp(48px,8vh,80px); padding-top: 24px; border-top: 1px solid var(--night-hairline); display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 16px; max-width: 1280px; margin-left: auto; margin-right: auto">

    <div style="display: flex; gap: 12px">
      <a href="https://www.instagram.com/vision2co.de" target="_blank" rel="noopener noreferrer" aria-label="Instagram"
        style="width: 40px; height: 40px; border-radius: 999px; border: 1px solid var(--night-hairline); display: inline-flex; align-items: center; justify-content: center; color: #fff; text-decoration: none">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="14" height="14" rx="4" stroke="currentColor" stroke-width="1.4"/><circle cx="10" cy="10" r="3.2" stroke="currentColor" stroke-width="1.4"/><circle cx="14.4" cy="5.6" r="0.8" fill="currentColor"/></svg>
      </a>
    </div>

    <div style="font-size: 13px; color: rgba(255,255,255,0.55)">{tr.footer_copyright}</div>

    <!-- Language switcher (plain links, no JS needed) -->
    <div style="display: flex; gap: 10px; font-size: 13px">
      <a href={lang === 'de' ? (isLegal ? '/impressum' : '/') : altHref}
        style={`color: ${lang === 'de' ? '#fff' : 'rgba(255,255,255,0.45)'}; text-decoration: none; font-weight: ${lang === 'de' ? 600 : 400}`}>DE</a>
      <span style="color: rgba(255,255,255,0.2)">/</span>
      <a href={lang === 'en' ? (isLegal ? (altLegalHref ?? '/en/imprint') : '/en/') : altHref}
        style={`color: ${lang === 'en' ? '#fff' : 'rgba(255,255,255,0.45)'}; text-decoration: none; font-weight: ${lang === 'en' ? 600 : 400}`}>EN</a>
    </div>

  </div>
</footer>
